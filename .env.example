# Backend
DATABASE_URL=sqlite+aiosqlite:///./data/nettest.db
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]
DEFAULT_PING_TARGET=8.8.8.8
DEFAULT_DNS_TARGETS=["google.com","cloudflare.com","github.com"]
DEFAULT_TRACEROUTE_TARGET=8.8.8.8
SPEED_TEST_TIMEOUT=60

# SMTP (optional, for email alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
